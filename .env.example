# ─── Railway Environment Variables ───────────────────────────────
# Set these in Railway dashboard → Variables

# PostgreSQL connection string (auto-set by Railway when you add a PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret key for JWT tokens (CHANGE THIS!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Token expiration (in minutes) — default 8 hours
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Port (auto-set by Railway, usually 8000)
PORT=8000

# ─── Textos legais (PDF e consistência com o frontend) ───────────
# Nome da profissional ou responsável citada no termo de uso de imagem
CLINICA_PROFISSIONAL_RESPONSAVEL=Gisele Santos
# Local exibido em “Local e data” nos termos (PDF)
CLINICA_LOCAL_ATENDIMENTO=Estabelecimento de saúde / registro eletrônico da clínica

# No frontend (Vite), use o prefixo VITE_ para as mesmas informações na tela:
# VITE_CLINICA_PROFISSIONAL_RESPONSAVEL=Gisele Santos
# VITE_CLINICA_LOCAL_ATENDIMENTO=Estabelecimento de saúde / registro eletrônico da clínica
